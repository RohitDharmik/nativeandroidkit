{
  "expo": {
    "name": "ContractIndia",
    "slug": "contractindia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
       
      "backgroundColor": "#0B2545"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.contractindia.app"
    },
    "android": {
      "package": "in.contractindia.app",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#0B2545"
      }
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ]
  }
}
